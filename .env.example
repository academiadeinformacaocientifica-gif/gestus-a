# ============================================
# CONFIGURAÇÃO SUPABASE
# ============================================
# Obtenha estes valores em: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# CONFIGURAÇÃO DE DESENVOLVIMENTO (OPCIONAL)
# ============================================

# Habilitar logs detalhados em desenvolvimento
VITE_DEBUG_LOGS=false

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA commit este arquivo ou .env.local
# 2. Copie este arquivo para .env.local: cp .env.example .env.local
# 3. Preencha com seus valores reais
# 4. Reinicie o servidor de desenvolvimento após mudanças: npm run dev
# 5. Em produção, configure essas variáveis no painel do seu hosting (Vercel, Netlify, etc)
